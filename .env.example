# Which keys you need depends on the model_location set in config.py (AppConfig):
#   cloud_only -> the cloud provider key (default cloud provider: Anthropic)
#   local_only -> a running local Ollama (LOCAL_OLLAMA_URL)
#   mixed      -> both

# --- LLM provider keys (set the one[s] your model_location uses) ---
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=        # only if a seam's service is "open_router"
HUGGINGFACE_HUB_KEY=       # only if a seam's service is "huggingface"

# Local Ollama host URL, e.g. http://localhost:11434/v1 (only for local_only / mixed)
LOCAL_OLLAMA_URL=""

# --- Federal Reserve data (always required to seed and run) ---
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- Test mode ---
# Development - offline tests only, no LLM/API calls (default for a fresh clone)
# Integration - also runs tests that call live LLMs / APIs (needs the keys above)
TEST_MODE=Development

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOGGING_LEVEL=INFO
LOG_FILE_PATH=""           # optional; leave empty to use LOG_FOLDER under the repo
LOG_FOLDER="logs"
